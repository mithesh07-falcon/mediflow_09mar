rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Is current user authenticated?
    function isAuth() {
      return request.auth != null;
    }

    // Helper: Get user document from the authenticated user's ID
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // --- COLLECTION: Users ---
    // Anyone can create their initial profile, then restricted to self
    match /users/{userId} {
      allow create: if isAuth() && request.auth.uid == userId;
      allow read, update: if isAuth() && (request.auth.uid == userId || isLinkedCaregiver(userId));
    }

    // --- COLLECTION: Links (Caregiver-Elder Relationship) ---
    // Holds mapping: {caregiverId: string, elderId: string, consented: boolean}
    match /links/{linkId} {
      allow create: if isAuth(); // Typically caregiver creates via invite code
      allow read: if isAuth() && (request.auth.uid == resource.data.caregiverId || request.auth.uid == resource.data.elderId);
      allow update: if isAuth() && (request.auth.uid == resource.data.elderId); // Only elder can confirm/revoke consent
    }

    // --- Helper for role-based sharing ---
    function isLinkedCaregiver(elderId) {
      // Logic for verifying caregiver access:
      // Search 'links' collection where elderId matches AND caregiverId matches current auth AND consented == true
      return exists(/databases/$(database)/documents/links/$(elderId + "_" + request.auth.uid)) && 
             get(/databases/$(database)/documents/links/$(elderId + "_" + request.auth.uid)).data.consented == true;
    }

    // --- COLLECTION: Health Records / Reminders ---
    // Only accessible by self or linked, consented caregiver
    match /health_records/{recordId} {
      allow create: if isAuth() && (request.resource.data.userId == request.auth.uid || isLinkedCaregiver(request.resource.data.userId));
      allow read, update, delete: if isAuth() && (resource.data.userId == request.auth.uid || isLinkedCaregiver(resource.data.userId));
    }

    // --- COLLECTION: Wallet Transactions ---
    // Only accessible by self or linked caregiver
    match /transactions/{txId} {
      allow create, read: if isAuth() && (request.auth.uid == request.resource.data.userId || isLinkedCaregiver(request.resource.data.userId));
    }

    // --- COLLECTION: Appointments ---
    match /appointments/{appId} {
      allow create, read, update: if isAuth() && (resource.data.patientId == request.auth.uid || isLinkedCaregiver(resource.data.patientId));
    }
  }
}
